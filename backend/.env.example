# Twilio SendGrid (Required for automated cashflow shock alerts)
SENDGRID_API_KEY="SG.your_api_key_here"
SENDGRID_FROM_EMAIL="alerts@yourdomain.com"
NOTIFY_USER_EMAIL="owner@yourdomain.com"
