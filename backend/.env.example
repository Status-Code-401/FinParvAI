# OpenAI API Key (Required for LangChain / OCR parsing and Context Agents)
OPENAI_API_KEY="sk-..."

# Pinecone API Key (Optional: For RAG Vector DB integration)
PINECONE_API_KEY="pk-..."

# Supabase (Required for database integration)
SUPABASE_URL="https://your-project-id.supabase.co"
